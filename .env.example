# Use 127.0.0.1 (not localhost) — on Windows + Node 18+, "localhost" can resolve
# to ::1 (IPv6) while Spring binds 0.0.0.0 (IPv4), causing ECONNREFUSED.
GATEWAY_URL=http://127.0.0.1:8080
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_MINIO_BASE_URL=http://127.0.0.1:9000/skladx
# Browser-side WebSocket gateway used for /api/v1/ws/chat (Phase 7).
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8080
